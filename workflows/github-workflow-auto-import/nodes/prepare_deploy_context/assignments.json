    "type": "string"
  },
  {
    "name": "workflowName",
    "value": "={{ $json.body.workflowName || '' }}",
    "type": "string"
  },
  {
    "name": "workflowPath",
    "value": "={{ $json.body.workflowPath || '' }}",
    "type": "string"
  },
  {
    "name": "rawUrl",
    "value": "={{ $json.body.rawUrl || '' }}",
    "type": "string"
  },
  {
    "name": "repository",
    "value": "={{ $json.body.repository || '' }}",
    "type": "string"
  },
  {
    "name": "branch",
    "value": "={{ $json.body.branch || '' }}",
    "type": "string"
  },
  {
    "name": "commitSha",
    "value": "={{ $json.body.commitSha || '' }}",
    "type": "string"
  }
